<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- list VIEW -->
<record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" width="250"/>
                <field name="bedrooms" width="80" class="text-end"/>
                <field name="garden" width="80" />
                <field name="expected_price" width="120" class="text-end"/>
                <field name="date_availability"  string="Availability Date" width="120" />
            </list>
        </field>
</record>

    <!-- FORM VIEW -->
 <record id="view_estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
        <form string="Property">
            <sheet>
               <group> 
                     <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="expected_price"/>
                        <field name="selling_price"/>
                    </group> 
                    <group>   
                        <field name="bedrooms"/>
                        <field name="living_area"/>
                        <field name="date_availability"/>
                        <field name="state"/>
                    </group>
                </group >   
                <notebook>
                    <page string="Garden">
                        <group>
                            <field name="garage"/>
                            <field name="garden"/>
                            <field name="garden_area"/>
                            <field name="garden_orientation"/>
                        </group>
                    </page> 

                </notebook>  
                  
            </sheet>
            <chatter position="bottom">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                    <field name="activity_ids" widget="mail_activity"/>
            </chatter>  
        </form>
     </field>
 </record>


<!--action-->
<record id="action_estate_property" model="ir.actions.act_window">
    <field name="name">Properties</field>
    <field name="res_model">estate.property</field>
    <field name="view_mode">list,form</field>   

</record>
<!--menuitem-->
<menuitem id="estate_menu_root" name="Estate"/>
<!--sub menuitem-->
<menuitem id="estate_ads_property" name="Advertisements" parent="estate_menu_root"/>
    <menuitem id="estate_menu_property" name="Properties"  action="action_estate_property" parent="estate_ads_property"/>


</odoo>