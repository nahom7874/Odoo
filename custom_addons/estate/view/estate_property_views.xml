<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- list VIEW -->
<record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Title" optional="show"/>
                <field name="postcode" optional="show"/>
                <field name="living_area"  string="Living Area (sqm)" optional="show" /> 
                <field name="selling_price" />
                <field name="bedrooms" optional="show" />
                <field name="garden"  optional="show"/>
                <field name="expected_price" />
                <field name="date_availability"  string="Availability Date" optional="show"/>
            </list>
        </field>
</record>

    <!-- FORM VIEW -->
 <record id="view_estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
        <form string="Property">
            <sheet>
               <group> 
                     <group>
                        <field name="name" string="Title"/>
                        <field name="postcode"/>
                        <field name="description"/>
                        <field name="expected_price"/>
                        <field name="selling_price"/>
                    </group> 
                    <group>   
                        <field name="bedrooms"/>
                        <field name="living_area"/>
                        <field name="date_availability"/>
                        <field name="state"/>
                    </group>
                </group >   
                <notebook>
                    <page string="Garden">
                        <group>
                            <field name="garage"/>
                            <field name="garden"/>
                            <field name="garden_area"/>
                            <field name="garden_orientation"/>
                        </group>
                    </page> 

                </notebook>  
                  
            </sheet>
            <chatter position="bottom">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids" widget="mail_thread"/>
                    <field name="activity_ids" widget="mail_activity"/>
            </chatter>  
        </form>
     </field>
 </record>
 <record id="view_estate_property_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Title"/>
                <field name="expected_price" string="Expected Price"/>
                <field name="bedrooms" string="Bedrooms"/>
                <field name="living_area" string="Living Area" filter_domain="[('living_area', '>=', self)]"/>
                <separator/>
                <filter name="filter_available" string="Available" domain="[('state','=','available')]"/>
                <filter name="filter_sold" string="Sold" domain="[('state','=','sold')]"/>
                
            </search>
        </field>
 </record>       


<!--action-->
<record id="action_estate_property" model="ir.actions.act_window">
    <field name="name">Properties</field>
    <field name="res_model">estate.property</field>
    <field name="view_mode">list,form</field>   

</record>
<!--menuitem-->
<menuitem id="estate_menu_root" name="Estate"/>
<!--sub menuitem-->
<menuitem id="estate_ads_property" name="Advertisements" parent="estate_menu_root"/>
    <menuitem id="estate_menu_property" name="Properties"  action="action_estate_property" parent="estate_ads_property"/>


</odoo>